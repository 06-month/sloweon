# Google Gemini Config
# Required only when using Gemini provider (Do not expose this to the client)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: server default is "gemini-1.5-flash"
GEMINI_MODEL=

# Anthropic Claude Config
# Required only when using Claude provider (Do not expose this to the client)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: server default is "claude-3-5-sonnet-20240620"
ANTHROPIC_MODEL=

# OpenAI Config
# Required only when using OpenAI provider (Do not expose this to the client)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: server default is "gpt-4o-mini"
OPENAI_MODEL=

# SK A.X Config
# Required only when using SK A.X provider (Do not expose this to the client)
SK_AX_API_KEY=your_sk_ax_api_key_here
# Optional: server default base URL
SK_AX_BASE_URL=
# Optional: server default is "skt-ax-llama3-ko"
SK_AX_MODEL=
# Optional: server default endpoint path is "/chat/completions"
SK_AX_CHAT_PATH=

# RAG Embedding Config
# Provider: openai (default) | gemini
EMBEDDING_PROVIDER=openai
# Optional: defaults to text-embedding-3-small (1536 dim)
OPENAI_EMBEDDING_MODEL=
# Optional: defaults to text-embedding-004
GEMINI_EMBEDDING_MODEL=

# Debugging and Monitoring Guards
# Optional: set to "true" to allow trace viewer and health check access on production
ADMIN_TRACE_VIEWER_ENABLED=false

# RAG Sync API (Vercel remote sync)
# Required in production when calling POST /api/admin/rag-sync
# Generate a long random string; never expose to the client
RAG_SYNC_SECRET=your_long_random_secret_here
