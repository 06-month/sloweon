# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SK A.X API Key & Base URL
SK_AX_API_KEY=your_sk_ax_api_key_here
# (Optional) SK A.X 콘솔/문서에서 endpoint가 별도로 제공되는 경우에만 입력
SK_AX_BASE_URL=

# OpenAI API Key & Model (Required only when using OpenAI provider)
# Do not expose this to the client
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL is optional; server default will be used when omitted (DEFAULT: gpt-4o-mini)
OPENAI_MODEL=
