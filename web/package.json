{
  "name": "sloweon-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/generate-asset-manifest.mjs && next dev",
    "build": "prisma generate && node scripts/generate-asset-manifest.mjs && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.10.0",
    "@tosspayments/tosspayments-sdk": "^2.7.1",
    "bcryptjs": "^3.0.2",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "prisma": "^6.10.0",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  },
  "allowScripts": {
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "@prisma/client@6.19.3": true
  }
}
